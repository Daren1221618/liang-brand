# ============================================================
# 亮品牌 · Nginx 反向代理配置示例
# 配合 Docker 部署使用，提供 HTTPS 和域名访问
#
# 使用方法：
#   1. 将此文件复制到 /etc/nginx/sites-available/liangbrand
#   2. 修改 server_name 为你的域名
#   3. 配置 SSL 证书（推荐使用 certbot）
#   4. ln -s /etc/nginx/sites-available/liangbrand /etc/nginx/sites-enabled/
#   5. nginx -t && systemctl reload nginx
# ============================================================

upstream liangbrand_backend {
    server 127.0.0.1:3001;
    keepalive 64;
}

server {
    listen 80;
    server_name your-domain.com;  # 修改为你的域名

    # HTTP 重定向到 HTTPS
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name your-domain.com;  # 修改为你的域名

    # SSL 证书配置（使用 certbot 自动配置）
    ssl_certificate /etc/letsencrypt/live/your-domain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/your-domain.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    # 安全头
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;

    # 代理配置
    location / {
        proxy_pass http://liangbrand_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;

        # SSE 流式传输（AI生成）必须关闭缓冲
        proxy_buffering off;
        proxy_cache off;

        # 超时设置（AI 生成长文本需要较长时间）
        proxy_connect_timeout 60s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;

        # 文件上传支持
        client_max_body_size 100m;
    }
